{
  "name": "live-streaming-app",
  "version": "1.0.0",
  "description": "Live streaming app that fetches and streams m3u8 channels in real-time",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "deploy:worker": "wrangler publish",
    "deploy:pages": "wrangler pages publish public",
    "deploy": "npm run deploy:worker && npm run deploy:pages"
  },
  "keywords": ["streaming", "m3u8", "hls", "cloudflare"],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "axios": "^1.6.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1"
  },
  "devDependencies": {
    "nodemon": "^3.0.1",
    "wrangler": "^3.0.0"
  }
}
